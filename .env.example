# LLM Provider Configuration
# Options: "ollama" or "gemini"
LLM_PROVIDER=ollama

# Default model to use
# For Ollama: "gemma3:4b", "qwen3:4b", "mistral:7b", "gemma4:31b-cloud", etc.
# For Gemini: "gemini-2.5-pro", "gemini-2.5-flash", etc.
DEFAULT_MODEL=gemma3:4b

# Ollama connection (optional)
# Local daemon (default) — cloud models offload through your signed-in Ollama app:
#   OLLAMA_HOST=http://localhost:11434
# Direct ollama.com cloud API (requires API key from https://ollama.com/settings/keys):
#   OLLAMA_CLOUD=true
#   OLLAMA_API_KEY=your_ollama_api_key_here
# Or set the host explicitly:
#   OLLAMA_HOST=https://ollama.com
#   OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_HOST=
OLLAMA_CLOUD=false
OLLAMA_API_KEY=

# Google Gemini API Key (required if using Gemini provider)
GEMINI_API_KEY=your_gemini_api_key_here
